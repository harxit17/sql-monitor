# SQL Monitor Backend Configuration
# Copy this to .env and fill in your values

# Server port
PORT=3001

# SQL Server connections (JSON array)
# Each entry: { "id": "unique-id", "label": "Display Name", "server": "hostname\\instance", "user": "sa", "password": "secret", "database": "master" }
# For Windows Auth: omit user/password and set "trustedConnection": true
SQL_SERVERS='[
  {
    "id": "SQLD01",
    "label": "DEVLAB",
    "server": "server name",
    "instanceName": "sql instance name",
    "user": "monitor_user",
    "password": "YourPasswordHere",
    "database": "master",
    "port": 1433,
    "encrypt": false,
    "trustServerCertificate": true
  }
]'
# Optional: refresh interval in seconds (default 30)
REFRESH_INTERVAL=30 
DASHBOARD_USERS='[
  {"username":"user","password":"password123"},
  {"username":"dba","password":"anotherpassword"}
]'